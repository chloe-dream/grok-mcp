# Local secrets — copy to .env.local and fill in.
# .env.local is gitignored; never commit your real keys.
#
# Load into the current PowerShell shell with:
#   Get-Content .env.local | ForEach-Object {
#     $k, $v = $_ -split '=', 2
#     if ($k -and -not $k.StartsWith('#')) { Set-Item "env:$k" $v }
#   }
#
# Or extract just the API key for one command:
#   $key = ((Get-Content .env.local | Select-String '^XAI_API_KEY=').Line -split '=', 2)[1]

XAI_API_KEY=xai-your-real-key-here
